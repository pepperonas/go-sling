<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0f0f14">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔗 go-sling receiver"
        android:textSize="24sp"
        android:textColor="#e8e8f0"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Server (e.g. 192.168.1.42:8420)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#e8e8f0" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="PIN (optional)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:textColor="#e8e8f0" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Save to folder">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:text="go-sling"
            android:textColor="#e8e8f0" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchExtract"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Auto-extract ZIP files"
        android:textColor="#e8e8f0"
        android:checked="true"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Receiving"
        android:textSize="16sp"
        android:backgroundTint="#6366f1" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textColor="#9494b0"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        android:gravity="center" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">
        <TextView
            android:id="@+id/txtLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5e5e7a"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2026 Martin Pfeffer | celox.io"
        android:textColor="#5e5e7a"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="8dp" />
</LinearLayout>
